      "parameters": {
        "jsCode": "const headersResponse = $('Fetch Headers').first().json;\n\n// Updated the fallback headers list to match your new 'Pre-Call' sheet structure\nconst headers = headersResponse.values ? headersResponse.values[0] : [\n  \"Full name\",\n  \"Work \",\n  \"Mobile\",\n  \"Email\",\n  \"First Name\",\n  \"Ex #\",\n  \"Phone Number\",\n  \"Last Name\",\n  \"Person City\",\n  \"Person State\",\n  \"Company Name\",\n  \"Revenue Range (in USD)\",\n  \"All Industries\",\n  \"All Sub-Industries\"\n];\n\nconst batchResponse = $('Fetch Batch').first().json;\nconst dataValues = batchResponse.values || [];\n\nif (dataValues.length === 0) {\n  return [{ json: { isEmpty: true } }];\n}\n\nconst startRow = $('Calculate Range1').first().json.start_row;\n\nreturn dataValues.map((row, index) => {\n  const result = { row_number: startRow + index };\n  headers.forEach((header, colIndex) => {\n    // Maps the value at the specific index to the header name\n    result[header] = row[colIndex] || '';\n  });\n  return { json: result };\n});"
      },
