    {
      "parameters": {
        "jsCode": "const DEFAULT_COUNTRY_CODE = '1';\nlet phone = $input.first().json.leadPhoneNumber || '';\nlet originalPhone = phone;\nconst e164Regex = /^\\+[1-9]\\d{9,14}$/;\nif (e164Regex.test(phone)) {\n  return { json: { ...$input.first().json, leadPhoneNumber: phone, phoneFormatted: true, originalPhoneNumber: originalPhone } };\n}\nlet hasPlus = phone.startsWith('+');\nlet digits = phone.replace(/\\D/g, '');\nif (digits.length === 0) {\n  return { json: { ...$input.first().json, leadPhoneNumber: '', phoneFormatted: false, phoneFormatError: 'No digits', originalPhoneNumber: originalPhone } };\n}\nlet formattedNumber;\nif (hasPlus) {\n  formattedNumber = '+' + digits;\n} else if (digits.length === 10) {\n  formattedNumber = '+' + DEFAULT_COUNTRY_CODE + digits;\n} else if (digits.length === 11 && digits.startsWith('1')) {\n  formattedNumber = '+' + digits;\n} else if (digits.length > 10 && digits.length <= 15) {\n  formattedNumber = '+' + digits;\n} else if (digits.length < 10) {\n  return { json: { ...$input.first().json, leadPhoneNumber: '+' + DEFAULT_COUNTRY_CODE + digits, phoneFormatted: false, phoneFormatError: 'Incomplete', originalPhoneNumber: originalPhone } };\n} else {\n  return { json: { ...$input.first().json, leadPhoneNumber: phone, phoneFormatted: false, phoneFormatError: 'Too long', originalPhoneNumber: originalPhone } };\n}\nif (e164Regex.test(formattedNumber)) {\n  return { json: { ...$input.first().json, leadPhoneNumber: formattedNumber, phoneFormatted: true, originalPhoneNumber: originalPhone } };\n} else {\n  return { json: { ...$input.first().json, leadPhoneNumber: formattedNumber, phoneFormatted: false, phoneFormatError: 'Invalid', originalPhoneNumber: originalPhone } };\n}"
      },
